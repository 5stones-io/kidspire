# Database — auto-set by Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:password@localhost:5432/kidsmin_development

# Redis — auto-set by Railway Redis plugin
REDIS_URL=redis://localhost:6379/0

# Rails
RAILS_MASTER_KEY=
RAILS_ENV=development
RAILS_LOG_LEVEL=info
PORT=3000
WEB_CONCURRENCY=2
CORS_ORIGINS=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=          # Project Settings > API > JWT Secret

# PCO OAuth — optional, required for PCO sync
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=
PCO_REDIRECT_URI=https://your-app.up.railway.app/auth/pco/callback
PCO_KIDS_MINISTRY_TAG=        # optional: filter PCO events by ministry tag

# Token encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Frontend
FRONTEND_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Twilio — optional, required for SMS invite links
# Sign up at twilio.com, get a phone number, copy from Console Dashboard
TWILIO_ACCOUNT_SID=              # starts with AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX  # your Twilio phone number

# Debug
DEBUG_PCO_SYNC=false
