# ============================================================
# kidsmin environment variables
# Local dev: copy to .env and fill in values.
# Production (Railway): set these in the Railway dashboard → Variables.
# ============================================================

# ── Database ─────────────────────────────────────────────────────────────────
# Local: postgresql://your_username@localhost:5432/kidspire_development
# Production: auto-provided by Railway PostgreSQL plugin (don't set manually)
DATABASE_URL=postgresql://chad@localhost:5432/kidspire_development

# ── Redis ─────────────────────────────────────────────────────────────────────
# Production: auto-provided by Railway Redis plugin
REDIS_URL=redis://localhost:6379/0

# ── Rails ─────────────────────────────────────────────────────────────────────
RAILS_ENV=development
RAILS_LOG_LEVEL=info
PORT=3000

# Production only — generate with: openssl rand -hex 64
# Set in Railway → Variables. No config/master.key needed.
SECRET_KEY_BASE=

# ── Domain ────────────────────────────────────────────────────────────────────
# Production: Railway sets RAILWAY_PUBLIC_DOMAIN automatically.
# Set CUSTOM_DOMAIN if you have one (e.g. kids.yourchurch.org).
CUSTOM_DOMAIN=

# ── Token encryption ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Dev:        http://localhost:3036
# Production: https://your-app.up.railway.app  (or https://CUSTOM_DOMAIN)
FRONTEND_BASE_URL=http://localhost:3036
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ── Email / magic links ───────────────────────────────────────────────────────
# Dev: leave SMTP_ADDRESS blank — magic link URLs print to the Rails console (🔐).
#
# Production with Resend (recommended — free tier, resend.com):
#   SMTP_ADDRESS=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USERNAME=resend
#   SMTP_PASSWORD=<your Resend API key>
#   SMTP_DOMAIN=yourdomain.com  (must be verified in Resend)
#   MAILER_FROM=noreply@yourdomain.com
#
# Other providers (Postmark, SendGrid): adjust address/port/credentials accordingly.
MAILER_FROM=noreply@kidsmin.app
SMTP_ADDRESS=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_DOMAIN=

# ── PCO OAuth ─────────────────────────────────────────────────────────────────
# Required for Planning Center sync.
# Create an OAuth app at: api.planningcenteronline.com/oauth/applications
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=
PCO_REDIRECT_URI=https://your-app.up.railway.app/auth/pco/callback
PCO_KIDS_MINISTRY_TAG=kidsmin  # create a tag with this exact name in PCO People → Tags

# ── Twilio ────────────────────────────────────────────────────────────────────
# Optional — required for SMS invite links.
# Note: trial accounts can only text verified numbers (10DLC needed for production).
TWILIO_ACCOUNT_SID=       # starts with AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Debug ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3036
