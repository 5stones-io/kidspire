<!DOCTYPE html>
<html>
<body style="font-family: sans-serif; max-width: 480px; margin: 0 auto; padding: 32px 16px; color: #1a1a1a;">
  <h2 style="font-size: 22px; margin-bottom: 8px;">Sign in to kidsmin</h2>
  <p style="color: #555; margin-bottom: 24px;">Click the button below to sign in. This link expires in 24 hours.</p>
  <a href="<%= @magic_link_url %>"
     style="display:inline-block;background:#6d28d9;color:#fff;padding:12px 28px;border-radius:99px;text-decoration:none;font-weight:600;">
    Sign in
  </a>
  <p style="margin-top: 24px; font-size: 13px; color: #888;">
    Or copy this URL into your browser:<br>
    <span style="word-break:break-all;"><%= @magic_link_url %></span>
  </p>
  <p style="margin-top: 16px; font-size: 12px; color: #aaa;">
    If you did not request this link, you can safely ignore this email.
  </p>
</body>
</html>
